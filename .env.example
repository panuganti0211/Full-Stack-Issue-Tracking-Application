# Supabase (required)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
VITE_SUPABASE_ANON_KEY=your-anon-key

# App URL (used in emails and share links)
VITE_APP_URL=http://localhost:3000

# Edge Functions — set in Supabase Dashboard → Edge Functions → Secrets
# RESEND_API_KEY=re_xxxxxxxx
# RESEND_FROM_EMAIL=TrackFlow <onboarding@resend.dev>
# APP_URL=http://localhost:3000
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key (auto-injected in Supabase)
